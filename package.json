{
  "name": "learning-speaking-app",
  "version": "0.29.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky install",
    "db:seed": "npx prisma db seed",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "qr:generate": "npx ts-node --project scripts/tsconfig.json scripts/generate-qr-codes.ts",
    "verify-env": "tsx scripts/verify-env.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@prisma/client": "^6.19.2",
    "@upstash/qstash": "^2.11.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.16.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "openai": "^6.39.0",
    "prisma": "^6.19.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "@next/swc-linux-x64-gnu": "15.5.14",
    "@rollup/rollup-linux-x64-gnu": "4.60.4",
    "@tailwindcss/oxide-darwin-arm64": "^4.2.2",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "swagger-ui-react": "^5.32.6",
    "tailwindcss": "^4.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.1"
  }
}
