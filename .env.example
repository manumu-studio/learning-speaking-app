# ============================================
# Learning Speaking App — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# Required vars will cause build/runtime errors if missing
# Optional vars degrade gracefully (features disabled)

# ── Required ──────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"
NEXTAUTH_SECRET="minimum-32-character-secret-for-jwt-signing"
NEXTAUTH_URL="http://localhost:3000"
AUTH_CLIENT_ID="your-oauth-client-id"
AUTH_CLIENT_SECRET="your-oauth-client-secret"
AUTH_ISSUER_URL="https://auth.manumustudio.com"  # OIDC provider base URL
APP_URL="http://localhost:3000"

# ── Optional: AI Analysis ────────────────────
# At least one required for speech analysis to work
OPENAI_API_KEY=""          # Whisper transcription
ANTHROPIC_API_KEY=""       # Claude Haiku analysis

# ── Optional: File Storage (R2) ──────────────
# Required for audio upload feature
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# ── Optional: Async Pipeline (QStash) ────────
# Required for production async processing
# Without these, dev mode uses synchronous fallback
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ── Optional: Rate Limiting (Upstash Redis) ──
# Without these, rate limiting is disabled (graceful degradation)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Azure Speech SDK (optional — required for pronunciation assessment feature)
# Get these from Azure Portal > Cognitive Services > Speech resource > Keys and Endpoint
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
