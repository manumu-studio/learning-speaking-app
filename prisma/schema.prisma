// Complete database schema for Learning Speaking App
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  CREATED
  UPLOADED
  CHUNKS_PROCESSING
  AWAITING_FINAL
  PROCESSING_FINAL
  TRANSCRIBING
  SCORING
  ANALYZING
  DONE
  FAILED
  CANCELLED
}

enum ChunkStatus {
  UPLOADED
  TRANSCRIBING
  SCORING
  CHUNK_DONE
  FAILED
}

enum ChunkResultStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ConsentFlag {
  AUDIO_STORAGE
  TRANSCRIPT_STORAGE
  PATTERN_TRACKING
  AI_DISCLOSURE
}

enum TimedFluencyStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model User {
  id             String           @id @default(cuid())
  externalId     String           @unique
  email          String?
  displayName    String?
  sessions         SpeakingSession[]
  drills           DrillAttempt[]
  consents         UserConsent[]
  vocabSuggestions  VocabSuggestion[]
  lexicon           UserWord[]
  fluencySessions   TimedFluencySession[]
  dailySummaries    DailySummary[]
  patternProfile    PatternProfile?
  settings         UserSettings?
  estimatedCefrLevel String?
  onboardedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  @@map("users")
}

model UserConsent {
  id        String      @id @default(cuid())
  userId    String
  flag      ConsentFlag
  granted   Boolean
  grantedAt DateTime    @default(now())
  revokedAt DateTime?
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, flag])
  @@map("user_consents")
}

model SpeakingSession {
  id             String        @id @default(cuid())
  userId         String
  status         SessionStatus @default(CREATED)
  durationSecs   Int?
  language       String        @default("en")
  topic          String?
  promptUsed     String?
  audioUrl       String?
  audioDeletedAt DateTime?
  errorMessage   String?
  focusNext      String?       @db.Text
  focusMetricKey String?       // Metric key user chose as focus for drill recommendations
  summary        String?       @db.Text
  intentLabel    String?       @db.Text
  location       String?
  registerFeedback Json?
  isOnboarding   Boolean       @default(false)
  isChunked      Boolean       @default(false)
  partialResults Boolean       @default(false)
  chunkCount     Int?
  processedAt    DateTime?
  transcript          Transcript?
  insights            Insight[]
  metrics             MetricSnapshot[]
  drills              DrillAttempt[]
  chunks              SessionChunk[]
  chunkResults        ChunkResult[]
  chunkFeatures       ChunkFeature[]
  pronunciationReport PronunciationReport?
  suggestedVocab      VocabSuggestion[] @relation("suggestedVocab")
  usedVocab           VocabSuggestion[] @relation("usedVocab")
  newWords            UserWord[]        @relation("lexiconFirstSeen")
  fluencyRound        TimedFluencyRound?
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  @@index([userId, createdAt])
  @@map("speaking_sessions")
}

model SessionChunk {
  id                String          @id @default(cuid())
  sessionId         String
  session           SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chunkIndex        Int
  status            ChunkStatus     @default(UPLOADED)
  durationSecs      Int
  overlapSecs       Float           @default(1.5)
  audioUrl          String?
  audioDeletedAt    DateTime?
  transcriptText    String?         @db.Text
  words             Json?
  wordCount         Int?
  pronScore         Float?
  accuracyScore     Float?
  fluencyScore      Float?
  completenessScore Float?
  prosodyScore      Float?
  speakingRateWpm   Float?
  pronWords         Json?
  pronRawJson       Json?
  errorMessage      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([sessionId, chunkIndex])
  @@index([sessionId, status])
  @@map("session_chunks")
}

model ChunkResult {
  id                  String            @id @default(cuid())
  sessionId           String
  session             SpeakingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chunkIndex          Int
  status              ChunkResultStatus @default(PENDING)
  durationSecs        Float
  overlapSecs         Float             @default(0)
  transcriptText      String?           @db.Text
  wordCount           Int?
  words               Json?
  pronunciationReport Json?
  insights            Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([sessionId, chunkIndex])
  @@index([sessionId])
  @@map("chunk_results")
}

model ChunkFeature {
  id          String          @id @default(cuid())
  sessionId   String
  chunkIndex  Int
  startMs     Int
  endMs       Int
  frameMs     Int             @default(10)
  f0Hz        Float[]
  intensityDb Float[]
  voiced      Boolean[]
  createdAt   DateTime        @default(now())
  session     SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@map("chunk_features")
}

model Transcript {
  id           String          @id @default(cuid())
  sessionId    String          @unique
  text         String          @db.Text
  improvedText String?         @db.Text
  wordsUsed    String[]        @default([])
  wordCount    Int?
  session      SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@map("transcripts")
}

model Insight {
  id         String          @id @default(cuid())
  sessionId  String
  category   String
  pattern    String
  detail     String          @db.Text
  frequency  Int?
  severity   String?
  examples   Json?
  suggestion String?         @db.Text
  session    SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@index([sessionId])
  @@map("insights")
}

model MetricSnapshot {
  id        String          @id @default(cuid())
  sessionId String
  session   SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  key       String
  level     String
  score     Int
  note      String?
  createdAt DateTime        @default(now())

  @@unique([sessionId, key])
  @@index([sessionId])
  @@map("metric_snapshots")
}

model DrillAttempt {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId     String?
  session       SpeakingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  drillType     String
  metricKey     String
  prompt        String           @db.Text
  sourceExample String?          @db.Text
  audioUrl      String?
  transcript    String?          @db.Text
  feedback      String?          @db.Text
  improved      Boolean?
  createdAt     DateTime         @default(now())
  completedAt   DateTime?

  @@index([userId, createdAt])
  @@index([sessionId])
  @@map("drill_attempts")
}

model PatternProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  patterns    Json
  focusAreas  Json?
  lastUpdated DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("pattern_profiles")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  dailyGoalMinutes     Int      @default(10)
  defaultDurationSecs  Int      @default(60)
  pronunciationEnabled Boolean  @default(true)
  theme                String   @default("system")
  phonemeAlphabet      String   @default("IPA")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model PronunciationReport {
  id                String              @id @default(cuid())
  sessionId         String              @unique
  session           SpeakingSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  pronScore         Float
  accuracyScore     Float
  fluencyScore      Float
  completenessScore Float
  prosodyScore      Float
  speakingRateWpm   Float
  azureLocale       String              @default("en-US")
  azureSdkVersion   String
  rawJson           Json
  failureReason     String?
  createdAt         DateTime            @default(now())
  words             WordPronunciation[]

  @@index([sessionId])
  @@map("pronunciation_reports")
}

model WordPronunciation {
  id                   String              @id @default(cuid())
  reportId             String
  report               PronunciationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  wordIndex            Int
  word                 String
  display              String?
  accuracyScore        Float
  errorType            String
  offsetMs             Int
  durationMs           Int
  breakErrorTypes      String[]
  intonationErrorTypes String[]
  monotonePitchDelta   Float?
  phonemes             Json
  l1Tags               String[]

  @@index([reportId, wordIndex])
  @@index([reportId, errorType])
  @@map("word_pronunciations")
}

model VocabSuggestion {
  id                   String           @id @default(cuid())
  userId               String
  word                 String
  meaning              String           @db.Text
  exampleSentence      String           @db.Text
  type                 String           @default("word")
  domain               String           @default("general")
  frequencyBand        String           @default("mid")
  suggestedInSessionId String
  firstUsedInSessionId String?
  firstUsedAt          DateTime?

  // SRS scheduling fields
  nextReviewAt         DateTime?
  interval             Int              @default(1)
  easeFactor           Float            @default(2.5)
  reviewCount          Int              @default(0)
  lastReviewedAt       DateTime?

  createdAt            DateTime         @default(now())
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestedInSession   SpeakingSession  @relation("suggestedVocab", fields: [suggestedInSessionId], references: [id], onDelete: Cascade)
  firstUsedInSession   SpeakingSession? @relation("usedVocab", fields: [firstUsedInSessionId], references: [id], onDelete: SetNull)

  @@unique([userId, word])
  @@index([userId, firstUsedInSessionId])
  @@index([userId, nextReviewAt])
  @@map("vocab_suggestions")
}

model UserWord {
  id                 String          @id @default(cuid())
  userId             String
  word               String
  cefrLevel          String          @default("b2")
  firstSeenAt        DateTime        @default(now())
  lastSeenAt         DateTime        @default(now())
  sessionCount       Int             @default(1)
  firstSeenSessionId String?

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstSeenSession SpeakingSession? @relation("lexiconFirstSeen", fields: [firstSeenSessionId], references: [id], onDelete: SetNull)

  @@unique([userId, word])
  @@index([userId, cefrLevel])
  @@index([userId, firstSeenAt])
  @@map("user_words")
}

model TimedFluencySession {
  id        String             @id @default(cuid())
  userId    String
  promptId  String
  status    TimedFluencyStatus @default(IN_PROGRESS)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  rounds    TimedFluencyRound[]
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("timed_fluency_sessions")
}

model TimedFluencyRound {
  id                String              @id @default(cuid())
  fluencySessionId  String
  fluencySession    TimedFluencySession @relation(fields: [fluencySessionId], references: [id], onDelete: Cascade)
  roundNumber       Int
  targetMinutes     Int
  speakingSessionId String?             @unique
  speakingSession   SpeakingSession?    @relation(fields: [speakingSessionId], references: [id], onDelete: SetNull)
  speechRateWpm     Float?
  fillerCount       Int?
  hesitationCount   Int?
  completedAt       DateTime?
  createdAt         DateTime            @default(now())

  @@unique([fluencySessionId, roundNumber])
  @@index([fluencySessionId])
  @@map("timed_fluency_rounds")
}

model DailySummary {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime @db.Date
  deliveryAvg       Float
  languageAvg       Float
  pronunciationAvg  Float
  newWords          String[]
  feedback          String   @db.Text
  sessionCount      Int
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_summaries")
}
