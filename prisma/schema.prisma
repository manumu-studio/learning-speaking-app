// Complete database schema for Learning Speaking App
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  CREATED
  UPLOADED
  CHUNKS_PROCESSING
  AWAITING_FINAL
  PROCESSING_FINAL
  TRANSCRIBING
  SCORING
  ANALYZING
  DONE
  FAILED
  CANCELLED
}

enum ChunkStatus {
  UPLOADED
  TRANSCRIBING
  SCORING
  CHUNK_DONE
  FAILED
}

enum ChunkResultStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ConsentFlag {
  AUDIO_STORAGE
  TRANSCRIPT_STORAGE
  PATTERN_TRACKING
  AI_DISCLOSURE
}

model User {
  id             String           @id @default(cuid())
  externalId     String           @unique
  email          String?
  displayName    String?
  sessions       SpeakingSession[]
  drills         DrillAttempt[]
  consents       UserConsent[]
  patternProfile PatternProfile?
  settings       UserSettings?
  onboardedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  @@map("users")
}

model UserConsent {
  id        String      @id @default(cuid())
  userId    String
  flag      ConsentFlag
  granted   Boolean
  grantedAt DateTime    @default(now())
  revokedAt DateTime?
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, flag])
  @@map("user_consents")
}

model SpeakingSession {
  id             String        @id @default(cuid())
  userId         String
  status         SessionStatus @default(CREATED)
  durationSecs   Int?
  language       String        @default("en")
  topic          String?
  promptUsed     String?
  audioUrl       String?
  audioDeletedAt DateTime?
  errorMessage   String?
  focusNext      String?       @db.Text
  focusMetricKey String?       // Metric key user chose as focus for drill recommendations
  summary        String?       @db.Text
  intentLabel    String?       @db.Text
  location       String?
  isOnboarding   Boolean       @default(false)
  isChunked      Boolean       @default(false)
  partialResults Boolean       @default(false)
  chunkCount     Int?
  processedAt    DateTime?
  transcript          Transcript?
  insights            Insight[]
  metrics             MetricSnapshot[]
  drills              DrillAttempt[]
  chunks              SessionChunk[]
  chunkResults        ChunkResult[]
  chunkFeatures       ChunkFeature[]
  pronunciationReport PronunciationReport?
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  @@index([userId, createdAt])
  @@map("speaking_sessions")
}

model SessionChunk {
  id                String          @id @default(cuid())
  sessionId         String
  session           SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chunkIndex        Int
  status            ChunkStatus     @default(UPLOADED)
  durationSecs      Int
  overlapSecs       Float           @default(1.5)
  audioUrl          String?
  audioDeletedAt    DateTime?
  transcriptText    String?         @db.Text
  words             Json?
  wordCount         Int?
  pronScore         Float?
  accuracyScore     Float?
  fluencyScore      Float?
  completenessScore Float?
  prosodyScore      Float?
  speakingRateWpm   Float?
  pronWords         Json?
  pronRawJson       Json?
  errorMessage      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([sessionId, chunkIndex])
  @@index([sessionId, status])
  @@map("session_chunks")
}

model ChunkResult {
  id                  String            @id @default(cuid())
  sessionId           String
  session             SpeakingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chunkIndex          Int
  status              ChunkResultStatus @default(PENDING)
  durationSecs        Float
  overlapSecs         Float             @default(0)
  transcriptText      String?           @db.Text
  wordCount           Int?
  words               Json?
  pronunciationReport Json?
  insights            Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([sessionId, chunkIndex])
  @@index([sessionId])
  @@map("chunk_results")
}

model ChunkFeature {
  id          String          @id @default(cuid())
  sessionId   String
  chunkIndex  Int
  startMs     Int
  endMs       Int
  frameMs     Int             @default(10)
  f0Hz        Float[]
  intensityDb Float[]
  voiced      Boolean[]
  createdAt   DateTime        @default(now())
  session     SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@map("chunk_features")
}

model Transcript {
  id        String          @id @default(cuid())
  sessionId String          @unique
  text      String          @db.Text
  wordCount Int?
  session   SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@map("transcripts")
}

model Insight {
  id         String          @id @default(cuid())
  sessionId  String
  category   String
  pattern    String
  detail     String          @db.Text
  frequency  Int?
  severity   String?
  examples   Json?
  suggestion String?         @db.Text
  session    SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@index([sessionId])
  @@map("insights")
}

model MetricSnapshot {
  id        String          @id @default(cuid())
  sessionId String
  session   SpeakingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  key       String
  level     String
  score     Int
  note      String?
  createdAt DateTime        @default(now())

  @@unique([sessionId, key])
  @@index([sessionId])
  @@map("metric_snapshots")
}

model DrillAttempt {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId     String?
  session       SpeakingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  drillType     String
  metricKey     String
  prompt        String           @db.Text
  sourceExample String?          @db.Text
  audioUrl      String?
  transcript    String?          @db.Text
  feedback      String?          @db.Text
  improved      Boolean?
  createdAt     DateTime         @default(now())
  completedAt   DateTime?

  @@index([userId, createdAt])
  @@index([sessionId])
  @@map("drill_attempts")
}

model PatternProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  patterns    Json
  focusAreas  Json?
  lastUpdated DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("pattern_profiles")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  dailyGoalMinutes     Int      @default(10)
  defaultDurationSecs  Int      @default(60)
  pronunciationEnabled Boolean  @default(true)
  theme                String   @default("system")
  phonemeAlphabet      String   @default("IPA")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model PronunciationReport {
  id                String              @id @default(cuid())
  sessionId         String              @unique
  session           SpeakingSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  pronScore         Float
  accuracyScore     Float
  fluencyScore      Float
  completenessScore Float
  prosodyScore      Float
  speakingRateWpm   Float
  azureLocale       String              @default("en-US")
  azureSdkVersion   String
  rawJson           Json
  failureReason     String?
  createdAt         DateTime            @default(now())
  words             WordPronunciation[]

  @@index([sessionId])
  @@map("pronunciation_reports")
}

model WordPronunciation {
  id                   String              @id @default(cuid())
  reportId             String
  report               PronunciationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  wordIndex            Int
  word                 String
  display              String?
  accuracyScore        Float
  errorType            String
  offsetMs             Int
  durationMs           Int
  breakErrorTypes      String[]
  intonationErrorTypes String[]
  monotonePitchDelta   Float?
  phonemes             Json
  l1Tags               String[]

  @@index([reportId, wordIndex])
  @@index([reportId, errorType])
  @@map("word_pronunciations")
}
